digraph Grid5x5 {
    layout = neato;
    splines = true;
    overlap = false;
    outputorder = edgesfirst;
    
    node [shape = box; width = 0.7; height = 0.7; fixedsize = true; fontsize = 20; fontcolor = red;];
    r0c0 [label = "";pos = "0,4!";];
    r0c1 [label = "";pos = "1,4!";];
    r0c2 [label = "";pos = "2,4!";];
    r0c3 [label = "";pos = "3,4!";];
    r0c4 [label = "";pos = "4,4!";];
    r1c0 [label = "";pos = "0,3!";];
    r1c1 [label = "";pos = "1,3!";];
    r1c2 [label = "";pos = "2,3!";];
    r1c3 [label = "";pos = "3,3!";];
    r1c4 [label = "";pos = "4,3!";];
    r2c0 [label = "";pos = "0,2!";];
    r2c1 [label = "";pos = "1,2!";];
    r2c2 [label = "";pos = "2,2!";];
    r2c3 [label = "";pos = "3,2!";];
    r2c4 [label = "";pos = "4,2!";];
    r3c0 [label = "";pos = "0,1!";];
    r3c1 [label = "";pos = "1,1!";];
    r3c2 [label = "";pos = "2,1!";];
    r3c3 [label = "";pos = "3,1!";];
    r3c4 [label = "O";pos = "4,1!";];
    r4c0 [label = "";pos = "0,0!";];
    r4c1 [label = "";pos = "1,0!";];
    r4c2 [label = "";pos = "2,0!";];
    r4c3 [label = "";pos = "3,0!";];
    r4c4 [label = "";pos = "4,0!";];
    
    edge [arrowsize = 0.8; penwidth = 1.5; headclip = false; tailclip = false;];
    edge [color = green;];
    r2c4 -> r2c3 -> r2c2 -> r1c2;
    edge [color = blue;];
    r1c2 -> r1c1 -> r2c1 -> r3c1 -> r3c2 -> r3c3 -> r3c4;
}